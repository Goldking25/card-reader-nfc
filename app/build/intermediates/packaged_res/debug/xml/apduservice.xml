<?xml version="1.0" encoding="utf-8"?>
<!--
  HCE APDU Service descriptor.
  Registers AID groups for payment and transit card emulation.
  "other" category ensures the app is always offered as a choice
  without replacing the default payment app.
-->
<host-apdu-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/hce_service_description"
    android:requireDeviceUnlock="false">

    <!--
      Generic payment AIDs (Visa, Mastercard, Amex, Rupay, UnionPay, etc.)
      Used for emulating ISO 14443-4 payment cards.
    -->
    <aid-group
        android:category="payment"
        android:description="@string/hce_payment_description">
        <!-- Visa -->
        <aid-filter android:name="A0000000031010" />
        <aid-filter android:name="A0000000032010" />
        <!-- Mastercard -->
        <aid-filter android:name="A0000000041010" />
        <aid-filter android:name="A0000000042010" />
        <!-- American Express -->
        <aid-filter android:name="A000000025" />
        <!-- Rupay / India -->
        <aid-filter android:name="A000000524010002" />
        <!-- UnionPay -->
        <aid-filter android:name="A000000333010101" />
        <!-- PPSE – Proximity Payment System Environment -->
        <aid-filter android:name="325041592E5359532E4444463031" />
    </aid-group>

    <!--
      Transit / other AIDs
      These AIDs cover common transit card systems globally.
    -->
    <aid-group
        android:category="other"
        android:description="@string/hce_transit_description">
        <!-- FeliCa Transit (generic) -->
        <aid-filter android:name="A000000151000000" />
        <!-- Calypso (French/European transit) -->
        <aid-filter android:name="315449432E494341" />
        <!-- Generic transit AID -->
        <aid-filter android:name="A0000004766C" />
        <!-- Opal / Australian transit -->
        <aid-filter android:name="A000000527210101" />
    </aid-group>

</host-apdu-service>
