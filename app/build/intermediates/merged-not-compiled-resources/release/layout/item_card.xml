<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.NfcPoc.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Type color badge strip -->
        <View
            android:id="@+id/viewTypeBadge"
            android:layout_width="4dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Card type -->
        <TextView
            android:id="@+id/tvCardType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textColor="@color/color_secondary"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/viewTypeBadge"
            app:layout_constraintEnd_toStartOf="@id/btnDeleteCard" />

        <!-- Card label -->
        <TextView
            android:id="@+id/tvCardLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginStart="12dp"
            android:textColor="@color/color_on_surface"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tvCardType"
            app:layout_constraintStart_toEndOf="@id/viewTypeBadge"
            app:layout_constraintEnd_toStartOf="@id/btnDeleteCard" />

        <!-- UID (monospace) -->
        <TextView
            android:id="@+id/tvCardUid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="12dp"
            android:fontFamily="monospace"
            android:textColor="@color/color_on_surface_dim"
            android:textSize="11sp"
            app:layout_constraintTop_toBottomOf="@id/tvCardLabel"
            app:layout_constraintStart_toEndOf="@id/viewTypeBadge"
            app:layout_constraintEnd_toStartOf="@id/btnDeleteCard" />

        <!-- Notes -->
        <TextView
            android:id="@+id/tvCardNotes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="12dp"
            android:textColor="@color/color_success"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tvCardUid"
            app:layout_constraintStart_toEndOf="@id/viewTypeBadge"
            app:layout_constraintEnd_toStartOf="@id/btnDeleteCard"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Timestamp (top-right) -->
        <TextView
            android:id="@+id/tvCardTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/color_on_surface_dim"
            android:textSize="10sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnDeleteCard"
            app:layout_constraintBottom_toTopOf="@id/btnDeleteCard" />

        <!-- Delete button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteCard"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@drawable/ic_delete"
            app:iconTint="@color/color_error"
            android:contentDescription="Delete card"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
